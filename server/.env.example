# ===== 基础服务 =====
HTTP_ADDR=:8080
PUBLIC_URL=http://127.0.0.1:8080
TLS_CERT=
TLS_KEY=

# ===== 数据存储 =====
DB_PATH=./data/linkall.db
OTA_DIR=./data/ota
LOG_DIR=./data/logs

# ===== 安全 =====
JWT_SECRET=change-me-to-a-long-random-string-please-32+chars
JWT_TTL_HOURS=720
ARGON2_TIME=2
ARGON2_MEMORY_KB=65536
ARGON2_THREADS=2
ARGON2_KEYLEN=32

# ===== 业务 =====
OFFICIAL_SERVER=http://127.0.0.1:8080
MAX_CONCURRENT_SESSIONS=200
SESSION_IDLE_TIMEOUT_MIN=30
DATA_RETENTION_DAYS=30
REQUIRE_DEVICE_CODE_DEFAULT=true
ALLOW_ANONYMOUS_DEFAULT=true
INVITE_DEFAULT_TTL_HOURS=72

# ===== TURN/STUN =====
STUN_URLS=stun:stun.l.google.com:19302
# 静态凭据模式（旧部署兼容）
TURN_URL=
TURN_USER=
TURN_CRED=
# coturn use-auth-secret 模式（推荐）：secret 与 coturn 配置的 static-auth-secret 一致
# 设置此值后服务端会生成短时凭据（默认 TTL 3600s）
TURN_SECRET=
TURN_CRED_TTL_SECS=3600
